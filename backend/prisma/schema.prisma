// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// 1. Definición de Enums
enum Rol {
  ADMIN
  ENCARGADO
  SOLICITANTE
}

enum TipoMovimiento {
  ENTRADA
  SALIDA
}

// 2. Modelo de Usuarios (Personal de la Facultad)
model Usuario {
  id              Int          @id @default(autoincrement())
  id_interno      String       @unique @db.VarChar(20)
  nombre          String       @db.VarChar(100)
  correo          String?      @db.VarChar(100)
  departamento    String       @db.VarChar(50)
  rol             Rol
  
  // Credenciales y Estado de Seguridad
  password        String?      @db.VarChar(255) 
  activo          Boolean      @default(true)   
  
  // Relaciones inversas
  solicitudes     Movimiento[] @relation("SolicitanteRel")
  registros       Movimiento[] @relation("EncargadoRel")
  auditorias      Auditoria[]  

  @@map("usuarios")
}

// 3. Modelo de Productos (Catálogo de Insumos)
model Producto {
  id            Int          @id @default(autoincrement())
  nombre        String       @db.VarChar(100)
  categoria     String       @db.VarChar(50)
  unidad_medida String       @db.VarChar(15)
  stock_actual  Decimal      @default(0.00) @db.Decimal(10, 2)
  stock_minimo  Decimal      @default(0.00) @db.Decimal(10, 2)
  
  embalajes     Embalaje[]
  movimientos   Movimiento[]

  @@map("productos")
}

// 4. Modelo de Embalajes (Conversión para compras a granel)
model Embalaje {
  id                Int      @id @default(autoincrement())
  producto_id       Int
  nombre_embalaje   String   @db.VarChar(50)
  factor_conversion Decimal  @db.Decimal(10, 2)
  
  producto          Producto @relation(fields: [producto_id], references: [id], onDelete: Cascade)

  @@map("embalajes")
}

// 5. Modelo de Movimientos (Bitácora Operativa Regular)
model Movimiento {
  id             Int            @id @default(autoincrement())
  producto_id    Int
  tipo           TipoMovimiento
  cantidad       Decimal        @db.Decimal(10, 2)
  solicitante_id Int?
  encargado_id   Int
  fecha          DateTime       @default(now()) // 🚀 Corregido: Prisma v7 gestiona los tipos de fecha nativos de PG de forma automática
  observaciones  String?        @db.Text

  producto       Producto       @relation(fields: [producto_id], references: [id], onDelete: Restrict)
  solicitante    Usuario?       @relation("SolicitanteRel", fields: [solicitante_id], references: [id], onDelete: SetNull)
  encargado      Usuario        @relation("EncargadoRel", fields: [encargado_id], references: [id], onDelete: Restrict)

  @@map("movimientos")
}

// 6. Modelo de Auditoría (Bitácora de Seguridad)
model Auditoria {
  id               Int      @id @default(autoincrement())
  usuario_id       Int      
  accion           String   @db.VarChar(100) 
  entidad          String   @db.VarChar(50)  
  entidad_id       Int?     
  detalles         String?  @db.Text         
  fecha            DateTime @default(now()) // 🚀 Corregido: Igualado a los estándares de la versión 7

  usuario          Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Restrict)

  @@map("auditoria")
}